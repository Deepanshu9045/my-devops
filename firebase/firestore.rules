rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function organization(orgId) {
      return get(/databases/$(database)/documents/organizations/$(orgId));
    }

    function isMember(orgId) {
      return signedIn() &&
        request.auth.uid in organization(orgId).data.memberIds;
    }

    function isAdmin(orgId) {
      return signedIn() &&
        request.auth.uid in organization(orgId).data.adminIds;
    }

    match /profiles/{userId} {
      allow read: if signedIn();
      allow create, update: if signedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /organizations/{orgId} {
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.auth.uid in request.resource.data.memberIds
        && request.auth.uid in request.resource.data.adminIds;

      allow read: if isMember(orgId);
      allow update, delete: if isAdmin(orgId);

      match /members/{memberId} {
        allow read: if isMember(orgId);
        allow create, update, delete: if isAdmin(orgId);
      }

      match /tasks/{taskId} {
        allow read: if isMember(orgId);
        allow create: if isMember(orgId)
          && request.resource.data.createdBy == request.auth.uid;
        allow update: if isMember(orgId);
        allow delete: if isAdmin(orgId);
      }
    }
  }
}
